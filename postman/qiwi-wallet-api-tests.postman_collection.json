{
  "info": {
    "name": "QIWI Wallet API Tests",
    "description": "Тестовое задание МКК «Луна» - тестирование API QIWI Кошелька. 4 проверки: доступность, баланс, создание платежа, исполнение платежа. Включает позитивные и негативные сценарии.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Health Check",
      "item": [
        {
          "name": "1.1 Get Payments - формат ответа",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/payment-history/v2/persons/{{wallet}}/payments?rows=1",
              "host": ["{{base_url}}"],
              "path": ["payment-history", "v2", "persons", "{{wallet}}", "payments"],
              "query": [{ "key": "rows", "value": "1" }]
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test(\"Status is 200/401/403/404\", () => {",
                "    pm.expect(pm.response.code).to.be.oneOf([200, 401, 403, 404]);",
                "});",
                "",
                "pm.test(\"Response body is valid or empty\", () => {",
                "    const body = pm.response.text();",
                "    if (body && body.length > 0) {",
                "        try {",
                "            JSON.parse(body);",
                "        } catch(e) {",
                "            pm.expect.fail('Response is not valid JSON: ' + body);",
                "        }",
                "    }",
                "});",
                "",
                "if (pm.response.code === 200) {",
                "    pm.test(\"Has data array\", () => {",
                "        const j = pm.response.json();",
                "        pm.expect(j).to.have.property('data');",
                "        pm.expect(j.data).to.be.an('array');",
                "    });",
                "} else if (pm.response.code !== 200 && pm.response.text().length > 0) {",
                "    pm.test(\"Error has code and message\", () => {",
                "        const j = pm.response.json();",
                "        pm.expect(j).to.have.property('code');",
                "        pm.expect(j).to.have.property('message');",
                "    });",
                "}"
              ]
            }
          }]
        },
        {
          "name": "1.2 Get Profile - формат ответа",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/person-profile/v1/profile/current",
              "host": ["{{base_url}}"],
              "path": ["person-profile", "v1", "profile", "current"]
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test(\"Status is 200/401/403/404\", () => {",
                "    pm.expect(pm.response.code).to.be.oneOf([200, 401, 403, 404]);",
                "});",
                "",
                "pm.test(\"Response body is valid or empty\", () => {",
                "    const body = pm.response.text();",
                "    if (body && body.length > 0) {",
                "        try {",
                "            JSON.parse(body);",
                "        } catch(e) {",
                "            pm.expect.fail('Response is not valid JSON: ' + body);",
                "        }",
                "    }",
                "});",
                "",
                "if (pm.response.code === 200) {",
                "    pm.test(\"Has authInfo, contractInfo, userInfo\", () => {",
                "        const j = pm.response.json();",
                "        pm.expect(j).to.have.property('authInfo');",
                "        pm.expect(j).to.have.property('contractInfo');",
                "        pm.expect(j).to.have.property('userInfo');",
                "    });",
                "}"
              ]
            }
          }]
        },
        {
          "name": "1.3 Без токена - 401/403/404",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/payment-history/v2/persons/{{wallet}}/payments?rows=1",
              "host": ["{{base_url}}"],
              "path": ["payment-history", "v2", "persons", "{{wallet}}", "payments"],
              "query": [{ "key": "rows", "value": "1" }]
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test(\"Status is 401/403/404 (auth required)\", () => {",
                "    pm.expect(pm.response.code).to.be.oneOf([401, 403, 404]);",
                "});"
              ]
            }
          }]
        }
      ]
    },
    {
      "name": "2. Balance Check",
      "item": [
        {
          "name": "2.1 Get Accounts - баланс > 0",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/funding-sources/v2/persons/{{wallet}}/accounts",
              "host": ["{{base_url}}"],
              "path": ["funding-sources", "v2", "persons", "{{wallet}}", "accounts"]
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test(\"Status is 200/401/403/404\", () => {",
                "    pm.expect(pm.response.code).to.be.oneOf([200, 401, 403, 404]);",
                "});",
                "",
                "pm.test(\"Response body is valid or empty\", () => {",
                "    const body = pm.response.text();",
                "    if (body && body.length > 0) {",
                "        try {",
                "            JSON.parse(body);",
                "        } catch(e) {",
                "            pm.expect.fail('Response is not valid JSON: ' + body);",
                "        }",
                "    }",
                "});",
                "",
                "if (pm.response.code === 200) {",
                "    pm.test(\"Has accounts array\", () => {",
                "        const j = pm.response.json();",
                "        pm.expect(j).to.have.property('accounts');",
                "        pm.expect(j.accounts).to.be.an('array').that.is.not.empty;",
                "    });",
                "",
                "    pm.test(\"All balances > 0\", () => {",
                "        const j = pm.response.json();",
                "        j.accounts.forEach(a => {",
                "            pm.expect(a.balance.amount).to.be.above(0,",
                "                `Balance for ${a.alias} should be > 0`);",
                "        });",
                "    });",
                "",
                "    pm.test(\"Accounts have required fields\", () => {",
                "        const j = pm.response.json();",
                "        j.accounts.forEach(a => {",
                "            pm.expect(a).to.have.property('alias');",
                "            pm.expect(a).to.have.property('currency');",
                "            pm.expect(a).to.have.property('balance');",
                "        });",
                "    });",
                "}"
              ]
            }
          }]
        },
        {
          "name": "2.2 Без токена - 401/403/404",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/funding-sources/v2/persons/{{wallet}}/accounts",
              "host": ["{{base_url}}"],
              "path": ["funding-sources", "v2", "persons", "{{wallet}}", "accounts"]
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test(\"Status is 401/403/404 (auth required)\", () => {",
                "    pm.expect(pm.response.code).to.be.oneOf([401, 403, 404]);",
                "});"
              ]
            }
          }]
        }
      ]
    },
    {
      "name": "3. Create Payment (1 RUB)",
      "item": [
        {
          "name": "3.1 Create payment - 1 RUB",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"{{payment_id}}\",\n  \"sum\": { \"amount\": 1, \"currency\": \"643\" },\n  \"paymentMethod\": { \"type\": \"Account\", \"accountId\": \"643\" },\n  \"fields\": { \"account\": \"{{recipient_wallet}}\" }\n}"
            },
            "url": {
              "raw": "{{base_url}}/sinap/api/terms/99/payments",
              "host": ["{{base_url}}"],
              "path": ["sinap", "api", "terms", "99", "payments"]
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test(\"Status is 200/400/401/403/404/500\", () => {",
                "    pm.expect(pm.response.code).to.be.oneOf([200, 400, 401, 403, 404, 500]);",
                "});",
                "",
                "pm.test(\"Response body is valid or empty\", () => {",
                "    const body = pm.response.text();",
                "    if (body && body.length > 0) {",
                "        try {",
                "            JSON.parse(body);",
                "        } catch(e) {",
                "            pm.expect.fail('Response is not valid JSON: ' + body);",
                "        }",
                "    }",
                "});",
                "",
                "if (pm.response.code === 200) {",
                "    pm.test(\"Has id, sum, transaction\", () => {",
                "        const j = pm.response.json();",
                "        pm.expect(j).to.have.property('id');",
                "        pm.expect(j).to.have.property('sum');",
                "        pm.expect(j).to.have.property('transaction');",
                "    });",
                "",
                "    pm.test(\"Amount is 1 RUB\", () => {",
                "        const j = pm.response.json();",
                "        pm.expect(j.sum.amount).to.equal(1);",
                "        pm.expect(j.sum.currency).to.equal('643');",
                "    });",
                "",
                "    pm.test(\"Transaction has state\", () => {",
                "        const j = pm.response.json();",
                "        pm.expect(j.transaction).to.have.property('state');",
                "    });",
                "",
                "    pm.environment.set('created_payment_id', pm.response.json().id);",
                "}"
              ]
            }
          }]
        },
        {
          "name": "3.2 Невалидная сумма (-1) - ошибка",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"{{payment_id}}\",\n  \"sum\": { \"amount\": -1, \"currency\": \"643\" },\n  \"paymentMethod\": { \"type\": \"Account\", \"accountId\": \"643\" },\n  \"fields\": { \"account\": \"{{recipient_wallet}}\" }\n}"
            },
            "url": {
              "raw": "{{base_url}}/sinap/api/terms/99/payments",
              "host": ["{{base_url}}"],
              "path": ["sinap", "api", "terms", "99", "payments"]
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test(\"Status is 400/401/403/404/500 (error)\", () => {",
                "    pm.expect(pm.response.code).to.be.oneOf([400, 401, 403, 404, 500]);",
                "});"
              ]
            }
          }]
        },
        {
          "name": "3.3 Без суммы - ошибка",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"{{payment_id}}\",\n  \"paymentMethod\": { \"type\": \"Account\", \"accountId\": \"643\" },\n  \"fields\": { \"account\": \"{{recipient_wallet}}\" }\n}"
            },
            "url": {
              "raw": "{{base_url}}/sinap/api/terms/99/payments",
              "host": ["{{base_url}}"],
              "path": ["sinap", "api", "terms", "99", "payments"]
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test(\"Status is 400/401/403/404/500 (error)\", () => {",
                "    pm.expect(pm.response.code).to.be.oneOf([400, 401, 403, 404, 500]);",
                "});"
              ]
            }
          }]
        },
        {
          "name": "3.4 Без токена - 401/403/404/500",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"{{payment_id}}\",\n  \"sum\": { \"amount\": 1, \"currency\": \"643\" },\n  \"paymentMethod\": { \"type\": \"Account\", \"accountId\": \"643\" },\n  \"fields\": { \"account\": \"{{recipient_wallet}}\" }\n}"
            },
            "url": {
              "raw": "{{base_url}}/sinap/api/terms/99/payments",
              "host": ["{{base_url}}"],
              "path": ["sinap", "api", "terms", "99", "payments"]
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test(\"Status is 401/403/404/500 (auth required)\", () => {",
                "    pm.expect(pm.response.code).to.be.oneOf([401, 403, 404, 500]);",
                "});"
              ]
            }
          }]
        }
      ]
    },
    {
      "name": "4. Payment Execution",
      "item": [
        {
          "name": "4.1 Get Payment Status",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/payment-history/v2/persons/{{wallet}}/payments/{{created_payment_id}}",
              "host": ["{{base_url}}"],
              "path": ["payment-history", "v2", "persons", "{{wallet}}", "payments", "{{created_payment_id}}"]
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test(\"Status is 200/400/401/403/404\", () => {",
                "    pm.expect(pm.response.code).to.be.oneOf([200, 400, 401, 403, 404]);",
                "});",
                "",
                "pm.test(\"Response body is valid or empty\", () => {",
                "    const body = pm.response.text();",
                "    if (body && body.length > 0) {",
                "        try {",
                "            JSON.parse(body);",
                "        } catch(e) {",
                "            pm.expect.fail('Response is not valid JSON: ' + body);",
                "        }",
                "    }",
                "});",
                "",
                "if (pm.response.code === 200) {",
                "    pm.test(\"Has id, sum, status\", () => {",
                "        const j = pm.response.json();",
                "        pm.expect(j).to.have.property('id');",
                "        pm.expect(j).to.have.property('sum');",
                "        pm.expect(j).to.have.property('status');",
                "    });",
                "",
                "    pm.test(\"Status is valid\", () => {",
                "        const j = pm.response.json();",
                "        pm.expect(j.status).to.be.oneOf(['WAITING', 'SUCCESS', 'ERROR', 'REJECTED']);",
                "    });",
                "}"
              ]
            }
          }]
        },
        {
          "name": "4.2 History schema validation",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/payment-history/v2/persons/{{wallet}}/payments?rows=5",
              "host": ["{{base_url}}"],
              "path": ["payment-history", "v2", "persons", "{{wallet}}", "payments"],
              "query": [{ "key": "rows", "value": "5" }]
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 200) {",
                "    pm.test(\"History has data array\", () => {",
                "        const j = pm.response.json();",
                "        pm.expect(j).to.have.property('data');",
                "        pm.expect(j.data).to.be.an('array');",
                "    });",
                "",
                "    if (pm.response.json().data.length > 0) {",
                "        pm.test(\"Payment has id, sum, status\", () => {",
                "            const p = pm.response.json().data[0];",
                "            pm.expect(p).to.have.property('id');",
                "            pm.expect(p).to.have.property('sum');",
                "            pm.expect(p).to.have.property('status');",
                "        });",
                "    }",
                "}"
              ]
            }
          }]
        },
        {
          "name": "4.3 Несуществующий платеж - 404",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/payment-history/v2/persons/{{wallet}}/payments/0",
              "host": ["{{base_url}}"],
              "path": ["payment-history", "v2", "persons", "{{wallet}}", "payments", "0"]
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test(\"Status is 400/401/403/404\", () => {",
                "    pm.expect(pm.response.code).to.be.oneOf([400, 401, 403, 404]);",
                "});"
              ]
            }
          }]
        }
      ]
    }
  ],
